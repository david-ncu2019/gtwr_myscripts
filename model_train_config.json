{
  "input_data": {
    "filename": "20251016_GTWR_InputData_DiffDisp_Layer_1.csv",
    "x_column": ["DIFFDISP"],
    "y_column": ["Layer_1"],
    "spatial_column": ["X_TWD97", "Y_TWD97"],
    "temp_column": ["monthly"],
    "id_column": ["id"]
  },
  
  "data_splitting": {
    "test_ratio": 0.15,
    "valid_ratio": 0.15,
    "sample_seed": 42
  },
  
  "model_architecture": {
    "dense_layers": [[3], [32, 16]],
    "drop_out": 0.2,
    "batch_norm": true,
    "start_lr": 0.001
  },
  
  "training": {
    "optimizer": "Adam",
    "max_epoch": 800,
    "early_stop": 500,
    "batch_size": 32,
    "use_gpu": true
  },
  
  "optimizer_params": {
    "_comment": "Supported schedulers: MultiStepLR, CosineAnnealingLR, CosineAnnealingWarmRestarts, Special, Constant",
    
    "scheduler": "MultiStepLR",
    "weight_decay": 0.0001,
    "scheduler_milestones": [200, 400, 600],
    "scheduler_gamma": 0.5,
    
    "_comment_cosine": "Alternative: CosineAnnealingLR",
    "_scheduler": "CosineAnnealingLR",
    "_scheduler_T_max": 800,
    "_scheduler_eta_min": 0.00001,
    
    "_comment_warm_restarts": "Alternative: CosineAnnealingWarmRestarts",
    "_scheduler_alt2": "CosineAnnealingWarmRestarts",
    "_scheduler_T_0": 100,
    "_scheduler_T_mult": 2,
    "_scheduler_eta_min_wr": 0.00001
  },
  
  "output": {
    "save_model": true,
    "save_coefficients": true,
    "save_predictions": true,
    "output_prefix": "gtnnwr_layer1"
  },
  
  "experiment": {
    "name": "Layer1_DIFFDISP_optimized",
    "description": "Experiment for Layer_1 ~ DIFFDISP with MultiStepLR",
    "notes": "Using MultiStepLR scheduler - reduces LR by 0.5x at epochs 200, 400, 600"
  }
}